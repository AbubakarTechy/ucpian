# SQLite database path (optional — defaults to server/data/campusnotes.db locally)
# SQLITE_PATH=./server/data/campusnotes.db

# Auth
JWT_SECRET=your_secure_random_secret
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Admin dashboard login
ADMIN_USERNAME=admin@ucp
ADMIN_PASSWORD=change_me

# Cloudinary (required on Vercel for PDF uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Or use a single URL instead:
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Client build-time variables (set in Vercel project settings)
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Optional: leave empty on Vercel so the app uses same-origin /api routes
# VITE_API_URL=
